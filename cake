    <script>
        // Enhanced scroll animations
        const observerOptions = {
            threshold: 0.15,
            rootMargin: '0px 0px -100px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('animated');
                }
            });
        }, observerOptions);

        document.querySelectorAll('.animate-scroll').forEach(el => {
            observer.observe(el);
        });

        // Navbar scroll behavior
        let lastScrollY = 0;
        window.addEventListener('scroll', () => {
            const navbar = document.querySelector('.navbar');
            
            // Background opacity
            const scrollPercent = (window.scrollY / 500) * 0.1;
            const opacity = Math.min(0.98, 0.95 + scrollPercent);
            navbar.style.background = `rgba(255, 255, 255, ${opacity})`;
            
            // Shadow on scroll
            if (window.scrollY > 50) {
                navbar.style.boxShadow = '0 12px 40px rgba(0,0,0,0.12)';
            } else {
                navbar.style.boxShadow = 'none';
            }

            // Active nav highlighting
            const sections = document.querySelectorAll('section[id]');
            let currentSection = '';
            sections.forEach(section => {
                const rect = section.getBoundingClientRect();
                if (rect.top <= 100 && rect.bottom >= 100) {
                    currentSection = section.id;
                }
            });

            document.querySelectorAll('.nav-links a').forEach(link => {
                link.classList.remove('active');
                if (link.getAttribute('href') === `#${currentSection}`) {
                    link.classList.add('active');
                }
            });
        });

        // FAB tooltip
        const fab = document.querySelector('.fab');
        fab.addEventListener('mouseenter', () => {
            fab.querySelector('span').style.opacity = '1';
        });
        fab.addEventListener('mouseleave', () => {
            fab.querySelector('span').style.opacity = '0';
        });

        // Smooth scrolling for all links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });

        // Preload critical resources
        window.addEventListener('load', () => {
            document.body.classList.add('loaded');
        });
    </script>
